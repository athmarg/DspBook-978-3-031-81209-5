   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "t = np.linspace(0, 12, 2000)\n",
    "x = np.cos(15 * np.pi * t) + 3 * np.sin(8 * np.pi * t)\n",
    "\n",
    "plt.figure(figsize=(10,4))\n",
    "plt.plot(t, x)\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
